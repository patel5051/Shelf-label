<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network access for Modisoft API sync -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Storage permissions for CSV file import via Storage Access Framework -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- NOTE: MANAGE_EXTERNAL_STORAGE is NOT required — SAF GetContent handles CSV access -->

    <!-- SUNMI printer binding (AIDL service) -->
    <uses-permission android:name="com.sunmi.permission.PRINTER" />

    <!-- Barcode scanner -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".ShelfLabelApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RetailShelfLabel">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            SUNMI Scanner Broadcast Receiver.
            android:exported="true" is REQUIRED — scan results come from the
            SUNMI firmware process (a different app).
        -->
        <receiver
            android:name=".sdk.ScannerReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.sunmi.scanner.ACTION_DATA_CODE_RECEIVED" />
                <action android:name="android.intent.ACTION_DECODE_DATA" />
            </intent-filter>
        </receiver>

        <!--
            FileProvider used to share the exported print history CSV via the
            Android share sheet. The authority must match the string used in
            FileProvider.getUriForFile() calls (packageName + ".fileprovider").
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

    </application>

</manifest>
