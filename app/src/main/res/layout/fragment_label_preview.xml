<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_preview_title"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
        android:textColor="@color/on_surface_variant"
        android:layout_marginBottom="12dp" />

    <!-- Live label preview (custom Canvas view) -->
    <com.retailshelflabel.ui.label.LabelView
        android:id="@+id/label_view"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@color/surface"
        android:elevation="2dp"
        android:layout_marginBottom="24dp" />

    <!-- Copy count picker -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/copies_label"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

        <NumberPicker
            android:id="@+id/number_picker_copies"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_print"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/print_label"
        android:textSize="16sp"
        android:layout_marginBottom="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_test_print"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/test_print"
        style="@style/Widget.Material3.Button.OutlinedButton" />

</LinearLayout>
