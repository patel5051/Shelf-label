<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Mode selector card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="1dp"
                app:cardCornerRadius="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/modisoft_sync_mode_label"
                        android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                        android:textColor="@color/on_surface_variant"
                        android:layout_marginBottom="12dp" />

                    <RadioGroup
                        android:id="@+id/rg_sync_mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rb_mode_api"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/modisoft_mode_api"
                            android:padding="8dp" />

                        <RadioButton
                            android:id="@+id/rb_mode_csv"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/modisoft_mode_csv"
                            android:padding="8dp" />

                        <RadioButton
                            android:id="@+id/rb_mode_manual"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/modisoft_mode_manual"
                            android:padding="8dp" />

                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- API credentials info card (shown in API mode) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_api_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardElevation="1dp"
                app:cardCornerRadius="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/modisoft_api_credentials_heading"
                        android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/modisoft_api_credentials_info"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="@color/on_surface_variant"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_open_api_settings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/open_settings"
                        style="@style/Widget.Material3.Button.OutlinedButton" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CSV file picker card (shown in CSV mode) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_csv_picker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardElevation="1dp"
                app:cardCornerRadius="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/modisoft_csv_heading"
                        android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/modisoft_csv_info"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="@color/on_surface_variant"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_pick_csv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/choose_pricebook_csv"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_csv_filename"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/no_file_selected"
                        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Manual placeholder card (shown in Manual mode) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_manual_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardElevation="1dp"
                app:cardCornerRadius="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/modisoft_manual_heading"
                        android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/modisoft_manual_info"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="@color/on_surface_variant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Last sync info -->
            <TextView
                android:id="@+id/tv_last_sync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/last_sync_never"
                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                android:textColor="@color/on_surface_variant"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <!-- Sync progress bar -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_sync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                app:trackCornerRadius="4dp" />

            <!-- Sync Now button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sync_now"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/sync_now"
                android:textSize="16sp"
                android:layout_marginBottom="24dp" />

            <!-- Sync log section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sync_log_heading"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_log_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sync_log_empty"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/on_surface_variant"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_sync_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
